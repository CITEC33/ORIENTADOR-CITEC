APP_NAME="UNES Orienta IA"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

LOG_CHANNEL=stack
LOG_LEVEL=debug

# --- Base de datos (recomendado: MySQL / PostgreSQL en producción) ---
DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=unes_orienta
# DB_USERNAME=root
# DB_PASSWORD=

# --- Sanctum: dominio(s) que puede tener cookie ---
SANCTUM_STATEFUL_DOMAINS=localhost,127.0.0.1,localhost:5173,127.0.0.1:5173

# --- CORS: dominios permitidos del frontend ---
FRONTEND_URL=http://localhost:5173

# --- Panel admin del bot ---
# PIN de acceso al panel admin (SOLO tú lo conoces). Cámbialo en producción.
ADMIN_PIN=1234-unes
# Segundos que dura la sesión de admin
ADMIN_SESSION_TTL=3600

# --- Bot IA (defaults; el panel admin sobreescribe estos valores en BD) ---
BOT_PROVIDER=openai
BOT_MODEL=gpt-4o-mini
BOT_API_BASE=https://api.openai.com/v1
# BOT_API_KEY se guarda cifrada en la BD desde el panel admin. NUNCA la pongas aquí en producción.

# --- Seguridad ---
SESSION_DRIVER=cookie
SESSION_LIFETIME=120
SESSION_SECURE_COOKIE=false
