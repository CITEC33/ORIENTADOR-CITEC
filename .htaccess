<IfModule mod_rewrite.c>
  RewriteEngine On

  RewriteRule ^\.builds - [F,L]
  RewriteRule ^api(/.*)?$ - [L]

  RewriteCond %{DOCUMENT_ROOT}/dist/$1 -f [OR]
  RewriteCond %{DOCUMENT_ROOT}/dist/$1 -d
  RewriteRule ^(.*)$ dist/$1 [L]

  RewriteRule ^assets/ - [R=404,L]

  RewriteRule ^.*$ dist/index.html [L]
</IfModule>

<IfModule mod_headers.c>
  Header set X-Powered-By "Hostinger Horizons"
  Header set Cache-Control "no-cache, no-store, must-revalidate"
  Header set Pragma "no-cache"
  Header set Expires "0"
  Header set CDN-Cache-Control "no-store"
  Header set Surrogate-Control "no-store"

  <If "%{REQUEST_URI} =~ m#^/assets/.*$#">
    Header set Cache-Control "public, max-age=604800"
    Header unset CDN-Cache-Control
    Header unset Surrogate-Control
  </If>
</IfModule>
